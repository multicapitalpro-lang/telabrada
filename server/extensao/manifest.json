{
  "manifest_version": 3,
  "name": "Captura Controlada",
  "version": "1.0",
  "description": "Captura dados apenas em página específica",
  "permissions": ["scripting"],
  "host_permissions": [
    "https://www.ne12.bradesconetempresa.b.br/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.ne12.bradesconetempresa.b.br/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}